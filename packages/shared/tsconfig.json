{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext", // <-- 把 CommonJS 改成 ESNext
    "moduleResolution": "node", // <-- 增加这一行，让找文件更聪明
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
